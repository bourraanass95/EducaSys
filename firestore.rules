rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isStaff() {
      return isSignedIn() && (getUserData().role == 'Staff' || getUserData().role == 'Admin');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Filieres collection
    match /filieres/{filiereId} {
      allow read: if true;
      allow write: if true;
    }

    // Staff collection
    match /staff/{staffId} {
      allow read: if true;
      allow write: if true;
    }

    // Applications collection
    match /applications/{applicationId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if true;
      allow write: if true;
    }

    // Structures collection
    match /structures/{structureId} {
      allow read: if true;
      allow write: if true;
    }

    // Schedules collection
    match /schedules/{scheduleId} {
      allow read: if true;
      allow write: if true;
    }

    // Attendance collection
    match /attendance/{attendanceId} {
      allow read: if true;
      allow write: if true;
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}

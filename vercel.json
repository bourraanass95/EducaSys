{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "firebase-applet-config.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/|assets/|favicon.ico|api-docs/).*)",
      "destination": "/index.html"
    }
  ]
}
